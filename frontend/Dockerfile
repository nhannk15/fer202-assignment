FROM node:22-alpine AS build
ARG VITE_BACKEND_ABSOLUTE_PATH=""
ENV VITE_BACKEND_ABSOLUTE_PATH=$VITE_BACKEND_ABSOLUTE_PATH
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
